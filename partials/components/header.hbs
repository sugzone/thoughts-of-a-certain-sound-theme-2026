{{#match headerStyle "!=" "Off"}}

    {{#match headerStyle "Highlight"}}
        {{> "components/header-content"}}
    {{else match headerStyle "Magazine"}}
        {{> "components/header-content"}}
    {{else}}
        {{#match headerStyle "Landing"}}
            {{> "components/latest-post"}}
        {{else}}
            {{> "components/header-content"}}
        {{/match}}
    {{/match}}

{{/match}}