{{#foreach posts limit="1"}}
<section class="gh-outer" aria-label="Latest post">

    <h2 style="display:none;">Newest post</h2>
    <article class="gh-latest-post-inner gh-inner" aria-labelledby="gh-latest-post-title">
        <div class="gh-latest-post-inner-header-row">
            <time class="gh-text-post-attributes" datetime="{{date format="YYYY-MM-DD"}}">
                {{date format="DD MMM YYYY"}}
            </time>
            {{#if primary_tag}}
                <span class="gh-text-post-attributes">{{primary_tag.name}}</span>
            {{/if}}
        </div>

        <div class="gh-latest-post-inner-body">
            <div class="gh-latest-post-left">
                <h3 class="is-title gh-header-text-tall-upper" id="gh-latest-post-title">
                    <a href="{{url}}">{{title}}</a>
                </h3>

                {{#if custom_excerpt}}
                    <p class="is-body">{{custom_excerpt}}</p>
                {{else}}
                    {{#if excerpt}}
                        <p class="is-body">{{excerpt}}</p>
                    {{/if}}
                {{/if}}
            </div>

            <div class="gh-latest-post-right">
                {{#if feature_image}}
                    <figure class="gh-latest-post-figure">
                        <img
                            class="gh-latest-post-image"
                            srcset="{{img_url feature_image size="xs" format="webp"}} 160w,
                                    {{img_url feature_image size="s" format="webp"}} 320w,
                                    {{img_url feature_image size="m" format="webp"}} 600w,
                                    {{img_url feature_image size="l" format="webp"}} 960w,
                                    {{img_url feature_image size="xl" format="webp"}} 1200w"
                            sizes="(max-width: 767px) 100vw, 50vw"
                            src="{{img_url feature_image size="m"}}"
                            alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
                            loading="eager"
                            width="600"
                            height="400"
                        >
                    </figure>
                {{/if}}
            </div>
        </div>

    </article>
</section>
{{/foreach}}
