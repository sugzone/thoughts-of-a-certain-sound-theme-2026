{{#get "posts" limit="4" filter=filter as |cards|}}
{{#if cards}}
<section class="gh-post-card-group gh-outer" aria-labelledby="gh-post-card-group-heading">
    <div class="gh-post-card-group-inner gh-inner">

        <h2 class="gh-post-card-group-heading is-title" id="gh-post-card-group-heading">Featured</h2>

        <div class="gh-post-card-group-feed">
            {{#foreach cards}}
            <article class="gh-post-card-group-item" aria-labelledby="gh-pcg-title-{{@index}}">

                {{#if primary_tag}}
                    <p class="gh-post-card-group-tag">{{primary_tag.name}}</p>
                {{/if}}

                {{#if feature_image}}
                    <figure class="gh-post-card-group-figure">
                        <img
                            class="gh-post-card-group-image"
                            srcset="{{img_url feature_image size="xs" format="webp"}} 160w,
                                    {{img_url feature_image size="s" format="webp"}} 320w,
                                    {{img_url feature_image size="m" format="webp"}} 600w,
                                    {{img_url feature_image size="l" format="webp"}} 960w"
                            sizes="(max-width: 767px) 100vw, 33vw"
                            src="{{img_url feature_image size="m"}}"
                            alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
                            loading="lazy"
                            width="600"
                            height="400"
                        >
                    </figure>
                {{/if}}

                <h3 class="gh-post-card-group-title is-title" id="gh-pcg-title-{{@index}}">
                    <a href="{{url}}">{{title}}</a>
                </h3>

                <time class="gh-post-card-group-date" datetime="{{date format="YYYY-MM-DD"}}">
                    {{date format="DD MMM YYYY"}}
                </time>

                {{#if custom_excerpt}}
                    <p class="gh-post-card-group-excerpt is-body">{{custom_excerpt}}</p>
                {{else}}
                    {{#if excerpt}}
                        <p class="gh-post-card-group-excerpt is-body">{{excerpt}}</p>
                    {{/if}}
                {{/if}}

            </article>
            {{/foreach}}
        </div>

    </div>
</section>
{{/if}}
{{/get}}
