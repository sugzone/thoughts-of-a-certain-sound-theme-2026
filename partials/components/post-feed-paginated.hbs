{{!--
    Reusable paginated post feed.
    Uses the page's native `posts` and `pagination` context — works on any
    collection or channel page (archive, tag, author, etc.)
--}}
<section class="gh-feed gh-outer" aria-label="Posts">
    <div class="gh-feed-inner gh-inner">

        <ul role="list">
            {{#foreach posts}}
            <li>
                <article class="gh-feed-post gh-canvas" aria-labelledby="gh-fp-title-{{@index}}">

                    <div class="gh-feed-post-content">

                        {{#if primary_tag}}
                            <a class="gh-article-tag gh-text-post-attributes gh-post-card-group-tag" href="{{primary_tag.url}}">{{primary_tag.name}}</a>
                        {{/if}}

                        {{#if feature_image}}
                            <figure class="gh-feed-post-figure">
                                <img
                                    class="gh-feed-post-image"
                                    srcset="{{img_url feature_image size="s" format="webp"}} 320w,
                                            {{img_url feature_image size="m" format="webp"}} 600w,
                                            {{img_url feature_image size="l" format="webp"}} 960w"
                                    sizes="(max-width: 767px) 100vw, 40vw"
                                    src="{{img_url feature_image size="m"}}"
                                    alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
                                    loading="lazy"
                                    width="600"
                                    height="400"
                                >
                            </figure>
                        {{/if}}

                        <h2 class="is-title gh-header-text-tall-upper" id="gh-fp-title-{{@index}}">
                            <a href="{{url}}">{{title}}</a>
                        </h2>

                        <div class="gh-feed-post-meta">
                            {{#if primary_author}}
                                <span class="gh-article-author-name">{{primary_author.name}}</span>
                            {{/if}}
                            <time class="gh-text-post-attributes gh-article-date" datetime="{{date format="M/DD/YYYY"}}">
                                {{date format="M/DD/YYYY"}}
                            </time>
                        </div>

                        

                        {{#if custom_excerpt}}
                            <p class="is-body">{{custom_excerpt}}</p>
                        {{else}}
                            {{#if excerpt}}
                                <p class="is-body">{{excerpt}}</p>
                            {{/if}}
                        {{/if}}

                        <a href="{{url}}" class="gh-button" aria-label="Read more: {{title}}">Read more</a>

                    </div>

                </article>
            </li>
            {{/foreach}}
        </ul>

        {{#match pagination.pages ">" 1}}
            {{pagination}}
        {{/match}}

    </div>
</section>
